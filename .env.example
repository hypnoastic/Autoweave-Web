GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPES=read:user,user:email,repo

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/autoweave_web
REDIS_URL=redis://redis:6379/0

RUNTIME_POSTGRES_URL=
RUNTIME_POSTGRES_SCHEMA=autoweave_runtime
RUNTIME_REDIS_URL=redis://redis:6379/0
RUNTIME_NEO4J_URL=
RUNTIME_NEO4J_USERNAME=
RUNTIME_NEO4J_PASSWORD=
RUNTIME_OPENHANDS_BASE_URL=http://openhands-agent-server:8000
RUNTIME_OPENHANDS_API_KEY=
RUNTIME_ARTIFACT_STORE_URL=file:///srv/autoweave/runtime/artifacts
RUNTIME_EXECUTION_MODE=queue
RUNTIME_VOLUME_NAME=autoweave_web_runtime
RUNTIME_VOLUME_MOUNT_PATH=/srv/autoweave

RUNTIME_VERTEX_PROJECT=autoweave-web-local
RUNTIME_VERTEX_LOCATION=global
RUNTIME_VERTEX_SERVICE_ACCOUNT_FILE=/srv/autoweave/runtime/control-plane/config/secrets/vertex_service_account.json

MAIL_FROM=hello@autoweave.local
SMTP_HOST=mailpit
SMTP_PORT=1025

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
