# Web app specific URLs / API keys
DATABASE_URL=
DOCKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/autoweave_web
REDIS_URL=redis://redis:6379/1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
MATRIX_HOMESERVER_PUBLIC_URL=http://localhost:8008
MATRIX_HOMESERVER_INTERNAL_URL=http://synapse:8008
MATRIX_SERVER_NAME=autoweave.local
MATRIX_REGISTRATION_SHARED_SECRET=
MATRIX_PASSWORD_SALT=autoweave-matrix-local
MATRIX_SYNC_TIMEOUT_MS=15000
MATRIX_SYNC_ENABLED=false
MATRIX_BRIDGE_LOCALPART=autoweave-bridge

# Library specific URLs / API keys
POSTGRES_URL=
DOCKER_RUNTIME_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/autoweave_web
NEO4J_URL=
NEO4J_USERNAME=
NEO4J_PASSWORD=
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=global
VERTEXAI_SERVICE_ACCOUNT_FILE=/srv/autoweave/runtime/control-plane/config/secrets/vertex_service_account.json

# Everything else
RUNTIME_POSTGRES_SCHEMA=autoweave_runtime
RUNTIME_REDIS_URL=redis://redis:6379/0
RUNTIME_OPENHANDS_BASE_URL=http://openhands-agent-server:8000
RUNTIME_OPENHANDS_API_KEY=
RUNTIME_ARTIFACT_STORE_URL=file:///srv/autoweave/runtime/artifacts
RUNTIME_EXECUTION_MODE=queue
RUNTIME_VOLUME_NAME=autoweave_web_runtime
RUNTIME_VOLUME_MOUNT_PATH=/srv/autoweave
MAIL_FROM=hello@autoweave.local
SMTP_HOST=mailpit
SMTP_PORT=1025

# Fill later only if the web app moves to OAuth instead of token login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Add Matrix flags only when you want the chat transport bridge enabled:
# FEATURE_FLAGS=ff_repo_installations_v1,ff_multi_repo_scope_v1,ff_human_loop_cards_v1,ff_inbox_v2,ff_artifact_center_v1,ff_search_command_v1,ff_matrix_chat_backend_v1,ff_matrix_room_provisioning_v1,ff_matrix_sync_ingest_v1
